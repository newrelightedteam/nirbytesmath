<style>
    .venusFooter {
        position: fixed;
        bottom: 20px;
        right: 20px;
        font-size: 10px;
        padding: 14px 34px;
        border: none;
        border-radius: 14px;
        text-decoration: none;
        background: #111;
        color: white;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        overflow: hidden;

        /* Glow */
        box-shadow:
            0 0 10px rgba(255, 0, 0, 0.5),
            0 0 20px rgba(255, 0, 0, 0.3);

        transition: 0.25s ease;
        animation: clickMePulse 1.5s infinite;
    }

    /* Animated glowing border */
    .venusFooter::before {
        content: "";
        position: absolute;
        inset: -2px;
        border-radius: inherit;

        background: conic-gradient(from 0deg,
                transparent,
                #ff0000,
                #ff4d4d,
                #ff0000,
                transparent);

        animation: rotateBorder 2s linear infinite;
        z-index: 0;
    }

    /* Inner background */
    .venusFooter::after {
        content: "";
        position: absolute;
        inset: 2px;
        border-radius: inherit;
        background: #111;
        z-index: 1;
    }

    /* Keep text above layers */
    .venusFooter span {
        position: relative;
        z-index: 2;
    }

    /* Hover */
    .venusFooter:hover {
        transform: scale(1.05);

        box-shadow:
            0 0 20px rgba(255, 0, 0, 0.8),
            0 0 40px rgba(255, 0, 0, 0.6);
    }

    /* Click effect */
    .venusFooter:active {
        transform: scale(0.95);
    }

    /* Border rotation */
    @keyframes rotateBorder {
        100% {
            transform: rotate(360deg);
        }
    }

    /* "Click Me" pulse animation */
    @keyframes clickMePulse {
        0% {
            transform: scale(1);
            box-shadow:
                0 0 10px rgba(255, 0, 0, 0.4),
                0 0 20px rgba(255, 0, 0, 0.2);
        }

        50% {
            transform: scale(1.06);
            box-shadow:
                0 0 20px rgba(255, 0, 0, 0.9),
                0 0 45px rgba(255, 0, 0, 0.7);
        }

        100% {
            transform: scale(1);
            box-shadow:
                0 0 10px rgba(255, 0, 0, 0.4),
                0 0 20px rgba(255, 0, 0, 0.2);
        }
    }
</style>

