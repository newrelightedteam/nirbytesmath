<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nirbytes - Math Science & Social Studies</title>
    <link rel="icon" type="image/png" href="/assets/fav/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/assets/fav/favicon.svg" />
    <link rel="shortcut icon" href="/assets/fav/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/fav/apple-touch-icon.png" />
    <link rel="manifest" href="/assets/fav/site.webmanifest" />
    <%- include('header') %>
        <style>
            body {
                margin: 0;
                padding: 0;
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                color: white;
                background-color: #222;
            }

            h1 {
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            }

            .search-container {
                display: flex;
                align-items: center;
                justify-content: space-evenly;
                margin-top: 20px;
            }

            .search-input {
                border: none;
                border-radius: 8px;
                padding: 20px 28px;
                width: 400px;
                font-size: 16px;
                outline: none;
                background-color: rgba(255, 255, 255, 0.8);
                color: #333;
            }

            .search-input::placeholder {
                color: #666;
            }

            .search-button {
                background-color: rgba(0, 0, 0, 0.7);
                border: none;
                border-radius: 25px;
                padding: 20px 28px;
                margin-left: 4px;
                cursor: pointer;
                outline: none;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 18px;
            }

            .search-button:hover {
                background-color: rgba(0, 0, 0, 0.9);
            }

            /* .venusFooter {

                text-decoration: none;
                background-color: black;
                padding: 10px 15px; border-radius: 5px;
            } */


            .reset-button {
                position: fixed;
                bottom: 20px;
                left: 50%;
                transform: translateX(-50%);
                background-color: rgba(0, 0, 0, 0.7);
                border: none;
                border-radius: 25px;
                color: white;
                padding: 10px 20px;
                font-size: 14px;
                cursor: pointer;
                outline: none;
                transition: background-color 0.2s;
                z-index: 1000;
            }

            .reset-button:hover {
                background-color: rgba(0, 0, 0, 0.9);
            }

            .app-buttons {
                display: flex;
                justify-content: center;
                margin-top: 20px;
            }

            .app-button {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 80px;
                height: 80px;
                border-radius: 8px;
                background-color: rgba(0, 0, 0, 0.7);
                margin: 0 10px;
                cursor: pointer;
                outline: none;
                border: none;
                color: white;
                text-decoration: none;
            }

            .app-button:hover {
                background-color: rgba(0, 0, 0, 0.9);
            }

            .app-button img {
                max-width: 60%;
                max-height: 60%;
            }

            #add-app-button {
                background-color: rgba(0, 0, 0, 0.7);
                color: white;
            }
        </style>
        <script src="/script.js"></script>
        <script>


            document.addEventListener('DOMContentLoaded', () => {
                init();
                const defaultBg = '/assets/backgrounds/foggy-forest.png';
                let bg = localStorage.getItem('bg') || defaultBg;
                document.body.style.backgroundImage = `url('https://static.vecteezy.com/system/resources/previews/072/281/214/non_2x/star-background-with-blue-stars-and-copy-space-on-dark-minimal-space-pattern-for-banners-posters-web-and-app-design-modern-cosmic-wallpaper-illustration-vector.jpg')`;
                const savedFont = localStorage.getItem('font');
                if (savedFont) document.body.style.fontFamily = savedFont;

                const searchInput = document.querySelector('.search-input');
                const searchButton = document.querySelector('.search-button');
                const appButtonsDiv = document.querySelector('.app-buttons');
                const addAppButton = document.getElementById('add-app-button');

                const createAppButton = (appName, appUrl) => {
                    const appButton = document.createElement('a');
                    appButton.href = '#';
                    appButton.classList.add('app-button');
                    appButton.textContent = appName;
                    appButton.addEventListener('click', (e) => { e.preventDefault(); encodeURL(appUrl); });
                    appButton.addEventListener('contextmenu', (e) => {
                        e.preventDefault();
                        const index = apps.findIndex(a => a.name === appButton.textContent);
                        if (index > -1) {
                            apps.splice(index, 1);
                            localStorage.setItem('apps', JSON.stringify(apps));
                            appButton.remove();
                        }
                    });
                    return appButton;
                };

                let apps = JSON.parse(localStorage.getItem('apps') || '[]');
                apps.forEach(app => {
                    const btn = createAppButton(app.name, app.url);
                    appButtonsDiv.insertBefore(btn, addAppButton);
                });

                const addAppModal = document.getElementById('add-app-modal');
                const addAppSubmit = document.getElementById('add-app-submit');
                const addAppCancel = document.getElementById('add-app-cancel');
                const appNameInput = document.getElementById('app-name');
                const appUrlInput = document.getElementById('app-url');

                addAppButton.addEventListener('click', () => addAppModal.style.display = 'flex');
                addAppCancel.addEventListener('click', () => addAppModal.style.display = 'none');
                addAppSubmit.addEventListener('click', () => {
                    const name = appNameInput.value;
                    let url = appUrlInput.value;
                    if (url && !url.startsWith('http')) url = 'https://' + url;
                    if (name && url) {
                        apps.push({ name, url });
                        localStorage.setItem('apps', JSON.stringify(apps));
                        const btn = createAppButton(name, url);
                        appButtonsDiv.insertBefore(btn, addAppButton);
                        addAppModal.style.display = 'none';
                        appNameInput.value = ''; appUrlInput.value = '';
                    }
                });

                searchButton.addEventListener('click', () => handleSearch(searchInput.value));
                searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') handleSearch(searchInput.value); });
            });
        </script>
</head>

<body>
    <%- include('parts/topbar.ejs') %>
        <div class="container">
            <%- include('brand') %>
                <div class="search-container">
                    <input type="text" class="search-input" placeholder="Search the web freely...">
                    <button class="search-button">➜</button>
                </div>
                <div class="app-buttons">
                    <a href="#" class="app-button"
                        onclick="event.preventDefault(); document.querySelector('.search-input').value = 'https://discord.com'; document.querySelector('.search-button').click();">
                        <img src="/assets/svg/discord.svg" alt="Discord">
                    </a>
                    <a href="#" class="app-button"
                        onclick="event.preventDefault(); document.querySelector('.search-input').value = 'https://play.geforcenow.com'; document.querySelector('.search-button').click();">
                        <img src="/assets/svg/geforcenow.svg" alt="Geforcenow">
                    </a>
                    <a href="#" class="app-button"
                        onclick="event.preventDefault(); document.querySelector('.search-input').value = 'https://youtube.com'; document.querySelector('.search-button').click();">
                        <img src="/assets/svg/youtube.svg" alt="Youtube">
                    </a>
                    <a href="#" class="app-button"
                        onclick="event.preventDefault(); document.querySelector('.search-input').value = 'https://spotify.com'; document.querySelector('.search-button').click();">
                        <img src="/assets/svg/spotify.svg" alt="Spotify">
                    </a>
                    <a href="#" class="app-button"
                        onclick="event.preventDefault(); document.querySelector('.search-input').value = 'https://x.com'; document.querySelector('.search-button').click();">
                        <img src="/assets/svg/x.svg" alt="Twitter/X">
                    </a>
                    <a href="#" class="app-button" id="add-app-button">
                        <img style="color:white" src="/assets/svg/plus.svg" alt="Add App">
                    </a>
                </div>
                <div id="add-app-modal"
                    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); justify-content: center; align-items: center; backdrop-filter: blur(5px); color: white;">
                    <div
                        style="background-color: rgba(0, 0, 0, 0.7); padding: 20px; border-radius: 10px; text-align: center;">
                        <h2 style="margin-bottom: 4px;">Add New App</h2>
                        <label>App Name:</label><br>
                        <input type="text" id="app-name"
                            style="border: none; border-radius: 25px; padding: 10px 20px; width: 200px; outline: none; background-color: rgba(255, 255, 255, 0.1); color: white;"><br><br>
                        <label>App URL:</label><br>
                        <input type="text" id="app-url"
                            style="border: none; border-radius: 25px; padding: 10px 20px; width: 200px; outline: none; background-color: rgba(255, 255, 255, 0.1); color: white;"><br><br>
                        <button id="add-app-submit"
                            style="background-color: rgba(27, 26, 26, 0.7); border: none; border-radius: 25px; padding: 10px 15px; cursor: pointer; color: white;">Add</button>
                        <button id="add-app-cancel"
                            style="background-color: rgba(27, 26, 26, 0.7); border: none; border-radius: 25px; padding: 10px 15px; cursor: pointer; color: white;">Cancel</button>
                    </div>
                </div>
        </div>
        <button class="reset-button" onclick="resetSiteData()">Reset Site Data</button>
        <%- include('brandFooter') %>
</body>

</html>