                            alt: "Traxmojo"
                        }
                    ];


                    function openApp(index) {
                        let opening = apps[index];

                        let url = opening.url;
                        handleSearch(url);

                    }

                    let appsHTML = '';
                    let appsGridParemt = document.querySelector('.games-grid');

                    apps.forEach((app, i) => {
                        appsHTML += `    <div data-id="${i}" class="game-card">
        <img class="game-thumb" src="${app.icon}">
        <div class="game-info">
            <div class="game-title">${app.name}</div>
        </div>
    </div>`;
                    })
                    appsGridParemt.innerHTML = appsHTML;
                    document.querySelector('.available').innerText = apps.length + ' available';

                    let gameCards = document.querySelectorAll('.game-card');
                    gameCards.forEach(gm => {
                        gm.onclick = function () {
                            let item = apps[gm.getAttribute('data-id')];
                            handleSearch(item?.url);
                        }
                    })

                    let searchInput = document.querySelector('#searchInput');

                    searchInput.oninput = function (e) {
                        let searchValue = searchInput.value;

                        const items = appsGridParemt.querySelectorAll('.game-card');

                        items.forEach(item => {
                            const text = item.querySelector('.game-title').textContent.toLowerCase();
                            const value = searchValue.toLowerCase();

                            if (text.includes(value)) {
                                item.style.display = "";
                            } else {
                                item.style.display = "none";
                            }
                        });

                    }


                });
            </script>